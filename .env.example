# FastAPI runtime host. Use 0.0.0.0 in containers or remote hosts.
APP_HOST=127.0.0.1

# FastAPI runtime port.
APP_PORT=8000

# FastAPI environment name used for logging and behavior toggles.
APP_ENV=development

# Public base URL for webhook callbacks from RingCentral.
# Example: https://your-domain.example.com
PUBLIC_BASE_URL=

# RingCentral client ID for the telephony application.
RC_CLIENT_ID=

# RingCentral client secret for the telephony application.
RC_CLIENT_SECRET=

# RingCentral server URL.
# Example sandbox: https://platform.devtest.ringcentral.com
# Example production: https://platform.ringcentral.com
RC_SERVER_URL=https://platform.ringcentral.com

# RingCentral JWT used to authenticate server-side API requests.
# This is used by the RingCentral Python SDK for platform login.
RC_JWT_TOKEN=

# RingCentral account ID expected in inbound webhook payloads.
RC_ACCOUNT_ID=

# Google Cloud project ID for Speech-to-Text usage and billing.
GOOGLE_CLOUD_PROJECT=

# Google credentials for Speech-to-Text.
# Provide either:
# - a path to the Google service account JSON file, or
# - the raw service account JSON itself on one line
GOOGLE_CREDENTIALS=

# Preferred Google Speech-to-Text recognition language code.
# Example: en-US
GOOGLE_STT_LANGUAGE_CODE=en-US

# OpenAI API key for GPT-4o conversation handling.
# This is currently optional because the active phone conversation runtime uses Gemini.
OPENAI_API_KEY=

# OpenAI model name used for the phone assistant runtime.
# This is currently optional because the active phone conversation runtime uses Gemini.
OPENAI_MODEL=gpt-4o

# Gemini API key used for call conversation management with Gemini 1.5 Flash.
GEMINI_API_KEY=

# Gemini model used for Ashley's conversation handling.
GEMINI_CONVERSATION_MODEL=gemini-2.5-flash

# Google API key used for Gemini 3.1 Flash TTS.
GOOGLE_API_KEY=

# Gemini prebuilt voice name used for Ashley's spoken voice.
# Example: Sulafat
GOOGLE_TTS_VOICE=Sulafat

# CaseDB endpoint used to save completed intake logs.
# Example: https://api.casedb.co/create_lead.php
CASEDB_LOG_URL=

# CaseDB API key used for authenticated requests.
CASEDB_API_KEY=

# CaseDB API secret used for authenticated requests.
CASEDB_API_SECRET=

# Optional explicit escalation endpoint. If blank, the app derives one from
# CASEDB_LOG_URL and you should confirm the final path with the CaseDB developer.
CASEDB_ESCALATION_URL=

# Default timeout in seconds for outbound HTTP requests to provider APIs.
HTTP_TIMEOUT_SECONDS=30
